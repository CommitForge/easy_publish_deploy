# Environment values for izipublish_sync systemd job.
# Copy to /etc/default/izipublish_sync and adjust values.

# Optional override for sync script location.
IZIPUBLISH_SYNC_SCRIPT=/root/izipublish/cron/izipublish_sync.sh

# Backend API base URL (without trailing /api/sync/{chainObjectId}).
SYNC_BACKEND_BASE_URL=http://localhost:8081/izipublish

# Chain object used by GET /api/sync/{chainObjectId}
SYNC_STATUS_CHAIN_ID=0x6c5215f9827413e25fad5f746e01c50e523caf704d65d4c7db35ddd38a8de30b

# Optional fallback for older configs that still set UPDATE_CHAIN_ID.
UPDATE_CHAIN_ID=0x6c5215f9827413e25fad5f746e01c50e523caf704d65d4c7db35ddd38a8de30b

# Curl timeout
SYNC_REQUEST_TIMEOUT_SECONDS=30
